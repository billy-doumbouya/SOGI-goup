generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String        @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(UNREAD)
  source    String        @default("website")
  createdAt DateTime      @default(now())
}

model Lead {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  interest  String?
  source    String   @default("website")
  createdAt DateTime @default(now())
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Formation {
  id          String          @id @default(cuid())
  title       String
  description String
  duration    String
  format      FormationFormat
  level       String
  price       String?
  imageUrl    String?
  syllabus    String?
  published   Boolean         @default(true)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PageContent {
  id        String   @id @default(cuid())
  page      String   @unique
  content   Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model ChatSession {
  id        String        @id @default(cuid())
  sessionId String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String
  content   String
  model     String?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [sessionId])
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

enum ContactStatus {
  UNREAD
  READ
  REPLIED
  ARCHIVED
}

enum FormationFormat {
  ONLINE
  HYBRID
  PRESENTIAL
}
